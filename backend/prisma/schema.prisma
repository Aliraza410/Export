generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  company   String?
  role      String   @default("user") // admin or user
  phase     String   @default("Phase 1")
  status    String   @default("Active")
  joinedAt  DateTime @default(now())
  profilePic String?
  
  documents      Document[]
  exportRequests ExportRequest[]
  registrations  RegistrationProgress[]
}

model Document {
  id        String   @id @default(uuid())
  userId    String
  title     String
  type      String
  status    String   @default("Draft")
  fileUrl   String?
  size      String?
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id])
}

model ExportRequest {
  id          String   @id @default(uuid())
  userId      String
  type        String   @default("Shipment")
  status      String   @default("Pending") // Pending, Active, Completed, Rejected
  priority    String   @default("Normal")
  product     String?
  qty         Int?
  destination String?
  shipping    String?
  totalCost   Float?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model RegistrationProgress {
  id        String   @id @default(uuid())
  userId    String
  type      String
  status    String   @default("Not Started")
  steps     Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  
  @@unique([userId, type])
}
